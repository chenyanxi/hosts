        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-41" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-21" value="混合完成后调度确认">
          <mxGeometry relative="1" as="geometry">
