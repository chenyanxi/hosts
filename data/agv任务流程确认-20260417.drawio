          <mxGeometry height="90" width="220" x="3974.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-84" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="自动取盖机 → 配料" vertex="1">
          <mxGeometry height="90" width="200" x="4284.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-85" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="前往翻转混合机&#xa;放料到混合机" vertex="1">
          <mxGeometry height="90" width="220" x="4574.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-86" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.8;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="AGV一直在混合机外等待&#xa;约10-15分钟" vertex="1">
          <mxGeometry height="90" width="240" x="4884.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-87" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="混合完成&#xa;混合机发送允许取料" vertex="1">
          <mxGeometry height="120" width="220" x="5224.615459735577" y="2147.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-88" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="AGV立即进入混合机取料" vertex="1">
          <mxGeometry height="90" width="220" x="5544.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-89" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="自动加盖机 → 卸料站 → 回到起点" vertex="1">
          <mxGeometry height="90" width="270" x="5864.615459735577" y="2162.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-90" parent="1" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="任务结束" vertex="1">
          <mxGeometry height="70" width="160" x="6234.615459735577" y="2172.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-91" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#14532D;fontSize=13;" value="优点&#xa;1. 混合完成时AGV已在混合机旁，允许取料与AGV到位基本同步。&#xa;2. 现场安全边界清楚，人员安全风险相对较低。&#xa;3. 仍可使用一次性整任务下发，接口逻辑简单。&#xa;4. 和设备方确认安全互锁时更直观。" vertex="1">
          <mxGeometry height="190" width="860" x="3974.615459735577" y="2562.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-92" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=1.5;fontColor=#92400E;fontSize=13;" value="缺点&#xa;1. AGV在混合机外等待10-15分钟，利用率偏低。&#xa;2. 等待期间不能去接其它任务，影响整体节拍。&#xa;3. 当AGV数量少时，产能损失更明显。&#xa;4. 多混合机并行时调度灵活性不足。" vertex="1">
          <mxGeometry height="190" width="860" x="4894.615459735577" y="2562.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-93" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#E11D48;strokeWidth=1.5;fontColor=#881337;fontSize=13;" value="风险&#xa;1. 主要风险不是现场人身安全，而是AGV长时间等待带来的产能风险。&#xa;2. 若混合异常超时，AGV会持续占位，影响后续调度。&#xa;3. 若业主更重视效率，可能认为该方案过于保守。" vertex="1">
          <mxGeometry height="190" width="860" x="5814.615459735577" y="2562.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-94" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="业主选择建议&#xa;适合优先考虑现场安全边界清晰、且接受AGV在混合阶段等待占用的场景。" vertex="1">
          <mxGeometry height="90" width="1600" x="3974.615459735577" y="2802.5384990985576" as="geometry" />
        </mxCell>
