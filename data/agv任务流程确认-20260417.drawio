          <mxGeometry height="30" width="460" x="3904.615459735577" y="1962.5384990985576" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-80" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#475569;" value="定义：AGV放料到翻转混合机后不离开，在混合机外持续等待，直到混合完成并立即取料" vertex="1">
          <mxGeometry height="20" width="980" x="3904.615459735577" y="1994.5384990985576" as="geometry" />
        </mxCell>
