        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-138" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="混合完成&#xa;混合机发送允许取料" vertex="1">
          <mxGeometry height="120" width="220" x="5517.076998197115" y="3292.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-139" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=1.8;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="AGV从其它位置返回混合机&#xa;到位可能延迟几分钟" vertex="1">
          <mxGeometry height="90" width="260" x="5827.076998197115" y="3307.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-140" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV到达后进入混合机取料" vertex="1">
          <mxGeometry height="90" width="220" x="6177.076998197115" y="3307.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-141" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="自动加盖机 → 卸料站 → 回到起点" vertex="1">
          <mxGeometry height="90" width="270" x="6487.076998197115" y="3307.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-142" parent="1" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="任务结束" vertex="1">
          <mxGeometry height="70" width="160" x="6847.076998197115" y="3317.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-143" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#14532D;fontSize=13;" value="优点&#xa;1. AGV放料后可立即离开，不必在混合机外空等。&#xa;2. AGV可去接其它任务，设备利用率更高。&#xa;3. 整体调度更灵活，更适合追求节拍和吞吐量的场景。" vertex="1">
          <mxGeometry height="180" width="920" x="3977.0769981971152" y="3717.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-144" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=1.5;fontColor=#92400E;fontSize=13;" value="缺点&#xa;1. 协议逻辑更复杂，需处理申请取料、允许取料、AGV回程到位的关系。&#xa;2. 混合完成与AGV实际到位之间存在时间脱开。&#xa;3. 与设备厂家联调时，需要反复确认光栅/安全门何时屏蔽、何时恢复。&#xa;4. 现场解释成本更高。" vertex="1">
          <mxGeometry height="180" width="980" x="4957.076998197115" y="3717.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-145" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFF1F2;strokeColor=#E11D48;strokeWidth=1.8;fontColor=#881337;fontSize=13;fontStyle=1;" value="风险&#xa;1. 混合机给出允许取料后，设备侧通常会同步屏蔽光栅/安全门。&#xa;2. 但AGV这时可能还在其它位置，返回混合机需要几分钟。&#xa;3. 在这段时间窗口内，如人员进入混合机区域，存在现实安全风险。&#xa;4. 该方案的核心风险是现场人身安全窗口，而不是单纯调度复杂度。" vertex="1">
          <mxGeometry height="200" width="980" x="5997.076998197115" y="3717.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-146" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="业主选择建议&#xa;适合优先考虑效率和设备利用率的场景；但若业主不接受混合完成后到AGV到位之间的现场安全窗口，则不建议采用本方案。" vertex="1">
          <mxGeometry height="100" width="1850" x="3977.0769981971152" y="3967.84619140625" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-147" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-133" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-134" value="一次派工">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-148" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-134" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-135" value="进入混合">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-149" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-135" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-136" value="放料后离开">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-150" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-136" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;" target="9IMCnS1bKPQ_ddZxgx-q-137" value="持续申请取料">
