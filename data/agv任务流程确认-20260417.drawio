<mxfile host="app.diagrams.net" agent="Codex drawio-diagrams-enhanced">
  <diagram id="agv-material-handshake" name="AGV送料取料安全交互">
    <mxGraphModel dx="-1248" dy="-525" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#0F172A;" value="混合机取料协议方案对比图" vertex="1">
          <mxGeometry height="30" width="360" x="3253.333333333333" y="1870.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#475569;" value="目标：比较“整任务一次性下发”与“混合前后两段下发”两种协议流程，并明确混合机允许取料后的安全风险窗口" vertex="1">
          <mxGeometry height="20" width="1100" x="3253.333333333333" y="1902.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-3" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#93C5FD;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="1160" width="1720" x="3253.333333333333" y="1950.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-4" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#86EFAC;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="1160" width="1720" x="5013.333333333333" y="1950.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-5" parent="1" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#1D4ED8;strokeWidth=1.5;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" value="方案A：接受风险，整任务一次性下发" vertex="1">
          <mxGeometry height="50" width="360" x="3283.333333333333" y="1970.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-6" parent="1" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;strokeWidth=1.5;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" value="方案B：不接受风险，任务分两段下发" vertex="1">
          <mxGeometry height="50" width="360" x="5043.333333333333" y="1970.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-7" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#334155;" value="主流程：自动取盖机 → 配料 → 混合 → 自动加盖机 → 卸料 → 回到起点" vertex="1">
          <mxGeometry height="20" width="820" x="3283.333333333333" y="2032.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-8" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#334155;" value="将混合流程拆为“前段任务”和“后段任务”，第二段在确认AGV已到混合机附近后再允许取料" vertex="1">
          <mxGeometry height="20" width="820" x="5043.333333333333" y="2032.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-9" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="SCADA一次性下发整任务&#xa;自动取盖机 / 配料 / 混合机 / 自动加盖机 / 卸料站" vertex="1">
          <mxGeometry height="110" width="260" x="3323.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-10" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV执行前段流程&#xa;取空罐 → 自动取盖机 → 配料 → 放料到翻转混合机" vertex="1">
          <mxGeometry height="110" width="260" x="3663.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-11" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV离开混合机后&#xa;持续发送申请取料信号" vertex="1">
          <mxGeometry height="110" width="240" x="4003.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-12" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="翻转混合机混合完成&#xa;发送允许取料信号&#xa;并通常同步屏蔽光栅/安全门" vertex="1">
          <mxGeometry height="140" width="220" x="4323.333333333333" y="2085.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-13" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=1.8;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="AGV此时可能在其它工位&#xa;从其它地方行驶回混合机取料&#xa;到位可能延迟数分钟" vertex="1">
          <mxGeometry height="110" width="250" x="4623.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-14" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFF1F2;strokeColor=#E11D48;strokeWidth=1.8;fontColor=#881337;fontSize=13;fontStyle=1;" value="风险窗口&#xa;允许取料已生效，但AGV尚未到位&#xa;若人员进入，存在安全风险" vertex="1">
          <mxGeometry height="120" width="520" x="4333.333333333333" y="2280.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-15" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV到达混合机并取料&#xa;然后进入自动加盖机 → 卸料站 → 回到起点" vertex="1">
          <mxGeometry height="110" width="280" x="4003.333333333333" y="2460.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-16" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#94A3B8;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="方案A说明&#xa;优点&#xa;1. SCADA只需一次派工，接口最简单。&#xa;2. AGV主流程连续，实施改动最小。&#xa;3. 可直接沿用原版流程图和现有任务模型。&#xa;&#xa;缺点&#xa;1. 混合完成后的取料允许信号与AGV实际到位时间脱开。&#xa;2. AGV可能要从其它工位返回，存在几分钟空档。&#xa;3. 安全逻辑与调度逻辑边界不清，联调容易反复确认。" vertex="1">
          <mxGeometry height="240" width="720" x="3323.333333333333" y="2670.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-17" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="第一段任务下发&#xa;自动取盖机 / 配料 / 混合机放料" vertex="1">
          <mxGeometry height="110" width="240" x="5083.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-18" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV执行第一段&#xa;取空罐 → 自动取盖机 → 配料 → 放料到翻转混合机" vertex="1">
          <mxGeometry height="110" width="280" x="5403.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-19" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="第一段结束&#xa;AGV离开混合机&#xa;任务1完成" vertex="1">
          <mxGeometry height="110" width="220" x="5763.333333333333" y="2100.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-20" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="混合机独立混合&#xa;不立即给AGV开放取料动作&#xa;安全互锁维持本地控制" vertex="1">
          <mxGeometry height="140" width="230" x="6063.333333333333" y="2085.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-21" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="SCADA确认混合完成&#xa;并确认AGV可调度至混合机附近/到位" vertex="1">
          <mxGeometry height="110" width="280" x="5083.333333333333" y="2320.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-22" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="第二段任务下发&#xa;仅下发：混合机取料 → 自动加盖机 → 卸料站 → 回到起点" vertex="1">
          <mxGeometry height="110" width="320" x="5463.333333333333" y="2320.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-23" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV先行驶到混合机附近/到位" vertex="1">
          <mxGeometry height="110" width="220" x="5863.333333333333" y="2320.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-24" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="翻转混合机发送允许取料信号&#xa;此时AGV已在近端/到位&#xa;风险窗口显著缩短或消除" vertex="1">
          <mxGeometry height="140" width="230" x="6163.333333333333" y="2305.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-25" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="AGV进入混合机取料&#xa;然后进入自动加盖机 → 卸料站 → 回到起点" vertex="1">
          <mxGeometry height="110" width="340" x="5463.333333333333" y="2510.0022764756945" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-26" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#94A3B8;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;" value="方案B说明&#xa;优点&#xa;1. 混合机允许取料信号可与AGV到位更紧密绑定。&#xa;2. 风险窗口显著缩短，安全边界更清楚。&#xa;3. 现场更容易向设备方和客户解释安全责任划分。&#xa;&#xa;缺点&#xa;1. SCADA需要两次派工，任务管理更复杂。&#xa;2. 需要增加第一段完成、混合完成待取、第二段启动等状态。&#xa;3. 异常恢复和超时处理需要额外设计。" vertex="1">
          <mxGeometry height="240" width="760" x="5083.333333333333" y="2670.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-27" parent="1" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#1E293B;strokeWidth=1.5;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" value="方案风险" vertex="1">
          <mxGeometry height="40" width="150" x="3323.333333333333" y="2950.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-28" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#E11D48;strokeWidth=1.8;fontColor=#881337;fontSize=13;fontStyle=1;" value="方案A风险&#xa;1. 混合机给出允许取料后，若同步屏蔽光栅/安全门，而AGV尚未到位，现场会出现可进入窗口。&#xa;2. 若此时人员进入混合机区域，存在现实安全风险。&#xa;3. 该风险需要客户明确接受，才能继续采用一次性下发。" vertex="1">
          <mxGeometry height="110" width="760" x="3513.333333333333" y="2940.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-29" parent="1" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=1.5;fontColor=#14532D;fontSize=13;fontStyle=1;" value="方案B风险&#xa;1. 主要风险转为系统复杂度风险，而不是现场人身安全风险。&#xa;2. 若两段任务衔接设计不好，可能出现待取卡死、重复派工、状态不同步。&#xa;3. 这些风险通常可以通过协议和状态机设计解决。" vertex="1">
          <mxGeometry height="110" width="586.67" x="4313.33" y="2940.22" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-30" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=1.5;fontColor=#0F172A;fontSize=13;fontStyle=1;" value="客户选择建议&#xa;1. 如果客户接受混合完成后到AGV到位之间存在安全窗口，可选择方案A。&#xa;2. 如果客户不接受该安全窗口，应选择方案B，并接受SCADA两段派工与更复杂的状态管理。&#xa;3. 建议客户在安全责任和系统复杂度之间做明确取舍，并在协议中固化。" vertex="1">
          <mxGeometry height="110" width="1440" x="5113.333333333333" y="2940.2222764756943" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-31" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-10" value="一次下发">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-32" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-11" value="前段执行">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-33" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;" target="9IMCnS1bKPQ_ddZxgx-q-12" value="持续申请取料">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-34" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D97706;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-13" value="允许取料">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-35" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E11D48;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-14" value="形成风险窗口">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9IMCnS1bKPQ_ddZxgx-q-36" edge="1" parent="1" source="9IMCnS1bKPQ_ddZxgx-q-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;endArrow=block;endFill=1;" target="9IMCnS1bKPQ_ddZxgx-q-15" value="AGV到位后取料">
          <mxGeometry relative="1" as="geometry">
