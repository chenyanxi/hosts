  <diagram id="agv-material-handshake" name="AGV送料取料安全交互">
    <mxGraphModel dx="-1248" dy="-525" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1400" math="0" shadow="0">
